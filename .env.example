# All values default to the host-mapped ports from docker-compose.yml, so the
# pipeline runs with no .env at all. Override here only if you change the compose
# setup or run the services inside the compose network.

# CAR_ID=1
# MQTT_URL=mqtt://localhost:51883
# RABBITMQ_URL=amqp://admin:admin@localhost:55672
# DATABASE_URL=postgres://postgres:postgres@localhost:55432/postgres
# QUEUE_NAME=car-events

# BUCKET_MS=5000            # output granularity (one row per 5s)
# GRACE_MS=10000            # how long to let out-of-order data settle before writing
# MAX_STALENESS_MS=300000   # carry-forward horizon; older values are written as NULL
# IDLE_TIMEOUT_MS=30000     # warn if the source goes quiet for this long

# Fallback only — real capacities are read from the MQTT stream at runtime.
# BATTERY_0_CAPACITY_WH=1000
# BATTERY_1_CAPACITY_WH=1000
